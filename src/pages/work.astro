---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import PortfolioPlaceholder from '../components/PortfolioPlaceholder.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

// Create an array with the existing projects plus 2 placeholders with external links
const displayItems = [
  ...projects,
  { 
    isPlaceholder: true, 
    title: "External Project 1", 
    img: "/public/assets/ENS Foundation.png",
    img_alt: "ens", 
    href: "https://ens-foundation.vercel.app/",
    external: true
  },
  { 
    isPlaceholder: true, 
    title: "External Project 2", 
    img: "/public/assets/BJBSolutions.png",
    img_alt: "External project 2 placeholder", 
    href: "https://ens-foundation.vercel.app/",
    external: true
  }
];
---

<BaseLayout
	title="My Work | Khetho Mngomezulu"
	description="Learn about Khetho Mngomezulu's most recent projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="My Work"
				tagline="See my most recent projects below to get an idea of my past experience. More available upon request."
				align="start"
			/>
			<Grid variant="offset">
				{
					displayItems.map((item) => (
						<li>
							{item.isPlaceholder ? (
								<PortfolioPlaceholder 
									title={item.title}
									img={item.img}
									img_alt={item.img_alt}
									href={item.href}
									external={item.external}
								/>
							) : (
								<PortfolioPreview project={item} />
							)}
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>